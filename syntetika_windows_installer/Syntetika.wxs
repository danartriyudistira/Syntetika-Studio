<?xml version="1.0"?>
<?define ProductVersion = "1.0.1"?>
<?define ProductUpgradeCode = "ba790d99-4d2c-4e33-a92d-219970637fca"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
   <Product Id="*" UpgradeCode="$(var.ProductUpgradeCode)" 
            Name="Syntetika Studio" Version="$(var.ProductVersion)" Manufacturer="Danar Tri Yudistira" Language="1033">
      <Package InstallerVersion="200" Compressed="yes" Comments="Windows Installer Package"/>
      <Media Id="1" Cabinet="product.cab" EmbedCab="yes"/>
      <Icon Id="ProductIcon" SourceFile="..\syntetika_icon.png"/>
      <Property Id="ARPPRODUCTICON" Value="ProductIcon"/>
      <Property Id="ARPHELPLINK" Value="https://github.com/danartriyudistira/Syntetika-Studio"/>
      <Property Id="ARPURLINFOABOUT" Value="https://github.com/danartriyudistira/Syntetika-Studio"/>
      <Property Id="ARPNOREPAIR" Value="1"/>
       <Upgrade Id="$(var.ProductUpgradeCode)">
          <UpgradeVersion OnlyDetect="yes" Minimum="$(var.ProductVersion)" IncludeMinimum="no" Property="NEWERVERSIONDETECTED"/>
          <UpgradeVersion Minimum="0.0.0" IncludeMinimum="yes" Property="OLDERVERSIONBEINGUPGRADED"/>
       </Upgrade>
       <Condition Message="A newer version of this software is already installed.">NOT NEWERVERSIONDETECTED</Condition>

      <Directory Id="TARGETDIR" Name="SourceDir">
         <Directory Id="ProgramFiles64Folder">
               <Directory Id="INSTALLDIR" Name="Syntetika Studio">
                <Component Id="ApplicationFiles" Guid="0a2563f0-5f49-4ae8-acda-143a019f73a2">
                    <File Id="MainExecutable" Source="..\build\Source\Syntetika_artefacts\Release\Syntetika.exe"/>
                    <File Id="Python3DLL" Source="..\build\Source\Syntetika_artefacts\Release\python3.dll"/>
                    <File Id="Python313DLL" Source="..\build\Source\Syntetika_artefacts\Release\python313.dll"/>
                    <File Id="License" Source="..\LICENSE"/>
                    <File Id="Readme" Source="readme.txt"/>
                </Component>
                <Directory Id="RESOURCE_DIR_REF" Name="resource">
                </Directory>
            </Directory>
         </Directory>

         <Directory Id="ProgramMenuFolder">
            <Directory Id="ProgramMenuSubfolder" Name="Syntetika Studio">
                <Component Id="ApplicationShortcuts" Guid="8f2ac8c2-b3bc-4d3c-8097-b62b5eed28ae">
                   <Shortcut Id="ApplicationShortcut1" Name="Syntetika Studio" Description="Syntetika Studio" 
                             Target="[INSTALLDIR]Syntetika.exe" WorkingDirectory="INSTALLDIR"/>
                   <RegistryValue Root="HKCU" Key="Software\Syntetika Studio" 
                             Name="installed" Type="integer" Value="1" KeyPath="yes"/>
                  <RemoveFolder Id="ProgramMenuSubfolder" On="uninstall"/>
               </Component>
            </Directory>
         </Directory>
      </Directory>

      <Property Id="WIXUI_INSTALLDIR" Value="INSTALLDIR" />
      <UI>
         <UIRef Id="WixUI_InstallDir" />
         <Publish Dialog="WelcomeDlg"
               Control="Next"
               Event="NewDialog"
               Value="InstallDirDlg"
               Order="2">1</Publish>
         <Publish Dialog="InstallDirDlg"
               Control="Back"
               Event="NewDialog"
               Value="WelcomeDlg"
               Order="2">1</Publish>
      </UI>

      <InstallExecuteSequence>
         <RemoveExistingProducts After="InstallValidate"/>
      </InstallExecuteSequence>

      <Feature Id="DefaultFeature" Level="1">
          <ComponentRef Id="ApplicationFiles"/>
          <ComponentRef Id="ApplicationShortcuts"/>
          <ComponentGroupRef Id="SyntetikaResourceDir" />
       </Feature>
   </Product>
</Wix>
